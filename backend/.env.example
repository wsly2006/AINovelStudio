# 后端环境变量示例
# 复制为 .env 后按需修改

# 数据库文件路径(相对 backend/ 目录)
DATABASE_URL=sqlite:///../data/app.db

# 前端开发服务器地址(用于 CORS)
FRONTEND_ORIGIN=http://localhost:5173

# 服务端口
HOST=127.0.0.1
PORT=8765

# ============ AI 配置(LiteLLM) ============
# 模型名遵循 LiteLLM 约定,见 https://docs.litellm.ai/docs/providers
# 工具会按 model 前缀决定 provider 并读取对应环境变量。

# 默认模型(改成你想用的即可)
AI_MODEL=claude-opus-4-7

# 可选:自托管 OpenAI 兼容端点的 base url
# AI_BASE_URL=http://localhost:11434/v1

# 生成参数
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# --- 各 provider 的 API key,只需配置你要用的那一个 ---

# Claude (model 形如 claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5-20251001)
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI (model 形如 gpt-4o / gpt-4-turbo)
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1

# DeepSeek (model 形如 deepseek/deepseek-chat / deepseek/deepseek-reasoner)
# DEEPSEEK_API_KEY=sk-xxx

# 阿里云通义 (model 形如 dashscope/qwen-max / dashscope/qwen-plus)
# DASHSCOPE_API_KEY=sk-xxx

# Moonshot Kimi (model 形如 moonshot/moonshot-v1-128k)
# MOONSHOT_API_KEY=sk-xxx

# Google Gemini (model 形如 gemini/gemini-2.0-flash)
# GEMINI_API_KEY=xxx

# Ollama 本地模型 (model 形如 ollama/qwen2.5:14b),无需 key
# AI_BASE_URL=http://localhost:11434
